  "inputs": [
    {"type": "minecraft:text", "key": "id", "label": "🔑 ID (benzersiz)", "max_length": 64},
    {"type": "minecraft:text", "key": "player", "label": "👤 Oyuncu Adı", "max_length": 16},
    {"type": "minecraft:text", "key": "permission", "label": "🔐 İzin Adı", "max_length": 64},
    {"type": "minecraft:number_range", "key": "level", "label": "⭐ Seviye", "start": 1, "end": 5, "step": 1, "initial": 1}
  ],
  "actions": [
    {
      "label": "✅ Ekle",
      "action": {
        "type": "minecraft:dynamic/run_command",
        "template": "/function custom_admin:api/permission/add {id:\"$(id)\",player:\"$(player)\",permission:\"$(permission)\",level:$(level)}"
      }
    },
    {
      "label": "❌ İptal",
      "action": {"type": "minecraft:suggest_command", "command": " "}
    }
  ]
