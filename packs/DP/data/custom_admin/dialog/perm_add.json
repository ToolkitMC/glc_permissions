{
  "type": "minecraft:multi_action",
  "title": {"text": "➕ İzin Ekle", "color": "green", "bold": true, "italic": false},
  "external_title": {"text": "➕ İzin Ekle", "color": "green", "italic": false},
  "body": {"type": "minecraft:plain_message", "contents": "§8Level: 1=Oyuncu  2=VIP  3=Mod  4=Admin  5=Owner"},
