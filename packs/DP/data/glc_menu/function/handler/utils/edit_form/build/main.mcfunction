# Hazırlık
tag @s add glc.show_pending
scoreboard players set @s glc_load_type 3
data remove storage glc:ui ui.body
function glc_menu:handler/dialog/loading/setup
scoreboard players set @s gulce_load.dialog 9

# TURKISH - Panel oluştur
execute if entity @s[tag=glc.lang_tr] run data modify storage glc:ui ui set value {type:"minecraft:multi_action",title:"Düzenleme Onayı",can_close_with_escape:1b,pause:0b,after_action:'close',columns:2,actions:[{label:"Evet",action:{type:"minecraft:show_dialog",dialog:{type:"minecraft:multi_action",title:"Düzenleyici",can_close_with_escape:1b,pause:0b,actions:[{label:"Ad Düzenle",action:{type:"minecraft:show_dialog",dialog:{type:"minecraft:multi_action",title:"Ad Değiştir",inputs:[{type:"minecraft:text",key:'old',label:"Eski Ad",label_visible:1b,max_length:100000,multiline:{}},{type:"minecraft:text",key:'new',label:"Yeni Ad",label_visible:1b,max_length:200000,multiline:{}}],can_close_with_escape:1b,pause:1b,actions:[{label:"Değiştir",action:{type:"minecraft:dynamic/run_command",template:"/function glc_menu:handler/utils/edit_form/setname {oname:\"$(old)\",nname:\"$(new)\"}"}}]}}},{label:"Eylem Düzenle",action:{type:"minecraft:show_dialog",dialog:{type:"minecraft:multi_action",title:"Eylem Düzenle",inputs:[{type:"minecraft:text",key:'id',label:"ID",label_visible:1b,max_length:2000000000},{type:"minecraft:text",key:'arg',label:"İçerik (JSON)",label_visible:1b,initial:"{}",max_length:2000000000,multiline:{}},{type:"minecraft:text",key:'t',label:"Eylem Tipi",label_visible:1b,max_length:2000000000},{type:"minecraft:text",key:'name',label:"Oyuncu Adı",label_visible:1b,max_length:1000000000,multiline:{}}],can_close_with_escape:1b,pause:0b,actions:[{label:"Değiştir",action:{type:"minecraft:dynamic/run_command",template:"/function glc_menu:handler/utils/edit_form/set_action {id:\"$(id)\",type:\"$(t)\",args:\"$(arg)\",name:\"$(name)\"}"}}]}}},{label:"Eylem Sil",action:{type:"minecraft:show_dialog",dialog:{type:"minecraft:multi_action",title:"Eylem Sil",inputs:[{type:"minecraft:text",key:'id',label:"ID",label_visible:1b,max_length:2000000000,multiline:{}}],can_close_with_escape:1b,pause:0b,actions:[{label:"Sil",action:{type:"minecraft:dynamic/run_command",template:"function glc_menu:handler/utils/edit_form/remove_action {id:\"$(id)\"}"}}]}}},{label:"Geri",action:{type:"minecraft:run_command",command:"/trigger gulce_menu"}}]}}},{label:"Hayır",action:{type:"minecraft:run_command",command:"/trigger gulce_menu set 2"}}]}

# ENGLISH - Panel oluştur
execute if entity @s[tag=glc.lang_en] run data modify storage glc:ui ui set value {type:"minecraft:multi_action",title:"Edit Confirmation",can_close_with_escape:1b,pause:0b,after_action:'close',columns:2,actions:[{label:"Yes",action:{type:"minecraft:show_dialog",dialog:{type:"minecraft:multi_action",title:"Editor",can_close_with_escape:1b,pause:0b,actions:[{label:"Edit Name",action:{type:"minecraft:show_dialog",dialog:{type:"minecraft:multi_action",title:"Change Name",inputs:[{type:"minecraft:text",key:'old',label:"Old Name",label_visible:1b,max_length:100000,multiline:{}},{type:"minecraft:text",key:'new',label:"New Name",label_visible:1b,max_length:200000,multiline:{}}],can_close_with_escape:1b,pause:1b,actions:[{label:"Change",action:{type:"minecraft:dynamic/run_command",template:"/function glc_menu:handler/utils/edit_form/setname {oname:\"$(old)\",nname:\"$(new)\"}"}}]}}},{label:"Edit Action",action:{type:"minecraft:show_dialog",dialog:{type:"minecraft:multi_action",title:"Edit Action",inputs:[{type:"minecraft:text",key:'id',label:"ID",label_visible:1b,max_length:2000000000},{type:"minecraft:text",key:'arg',label:"Content (JSON)",label_visible:1b,initial:"{}",max_length:2000000000,multiline:{}},{type:"minecraft:text",key:'t',label:"Action Type",label_visible:1b,max_length:2000000000},{type:"minecraft:text",key:'name',label:"Player Name",label_visible:1b,max_length:1000000000,multiline:{}}],can_close_with_escape:1b,pause:0b,actions:[{label:"Change",action:{type:"minecraft:dynamic/run_command",template:"/function glc_menu:handler/utils/edit_form/set_action {id:\"$(id)\",type:\"$(t)\",args:\"$(arg)\",name:\"$(name)\"}"}}]}}},{label:"Delete Action",action:{type:"minecraft:show_dialog",dialog:{type:"minecraft:multi_action",title:"Delete Action",inputs:[{type:"minecraft:text",key:'id',label:"ID",label_visible:1b,max_length:2000000000,multiline:{}}],can_close_with_escape:1b,pause:0b,actions:[{label:"Delete",action:{type:"minecraft:dynamic/run_command",template:"function glc_menu:handler/utils/edit_form/remove_action {id:\"$(id)\"}"}}]}}},{label:"Back",action:{type:"minecraft:run_command",command:"/trigger gulce_menu"}}]}}},{label:"No",action:{type:"minecraft:run_command",command:"/trigger gulce_menu set 2"}}]}

