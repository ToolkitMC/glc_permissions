{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:component",
    "component": "minecraft:custom_data",
    "cases": [
      {
        "when": "{glcMenu:1b}",
        "model": {
          "type": "minecraft:model",
          "model": "custom_admin:item/gulce_menu"
        }
      },
      {
        "when": "{glcModKit:1b}",
        "model": {
          "type": "minecraft:model",
          "model": "custom_admin:item/glc_mod_kit"
        }
      },
      {
        "when": "{glcAdminPanel:1b}",
        "model": {
          "type": "minecraft:model",
          "model": "custom_admin:item/glc_admin_panel"
        }
      },
      {
        "when": "{glcQuickAction:1b}",
        "model": {
