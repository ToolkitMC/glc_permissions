        }
      },
      {
        "when": "{glcSpy:1b}",
        "model": {
          "type": "minecraft:model",
          "model": "custom_admin:item/glc_spy"
        }
      },
      {
        "when": "{glcBroadcast:1b}",
        "model": {
          "type": "minecraft:model",
          "model": "custom_admin:item/glc_broadcast"
        }
      },
      {
        "when": "{glcTpa:1b}",
        "model": {
          "type": "minecraft:model",
